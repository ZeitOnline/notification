{
  "name": "@zeitonline/notify",
  "version": "0.1.1",
  "description": "Notify keeps you informed about results, warnings and errors.",
  "author": {
    "name": "DIE ZEIT",
    "email": "engineering@zeit.de"
  },
  "homepage": "https://github.com/ZeitOnline/notify#readme",
  "license": "MIT",
  "type": "module",
  "main": "./dist/notify.js",
  "module": "./dist/notify.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/notify.js",
      "default": "./dist/notify.js"
    }
  },
  "files": [
    "dist",
    "index.d.ts",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "demo": "vite --open demo/index.html",
    "test": "vitest run tests/notify.test.ts",
    "test:guidepup": "vitest run tests/notify.guidepup.test.ts --test-timeout=30000 --maxWorkers=1",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@guidepup/virtual-screen-reader": "^0.32.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/user-event": "^14.6.1",
    "jsdom": "^29.0.0",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ZeitOnline/notify.git"
  },
  "keywords": [
    "ui",
    "toaster",
    "notification",
    "alerts",
    "status messages",
    "feedback",
    "real-time updates"
  ]
}
